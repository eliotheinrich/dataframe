@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(fmt REQUIRED)

set(dataframe_INCLUDE_DIR "@CMAKE_INSTALL_PREFIX@/include")
set(dataframe_LIBRARY_DIR "@CMAKE_INSTALL_PREFIX@/lib")
include("${CMAKE_CURRENT_LIST_DIR}/dataframeTargets.cmake")

target_include_directories(dataframe::dataframe INTERFACE
    "${dataframe_INCLUDE_DIR}"
    "${dataframe_INCLUDE_DIR}/dataframe"
)

